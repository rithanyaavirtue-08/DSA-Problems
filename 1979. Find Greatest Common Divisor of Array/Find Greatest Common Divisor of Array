class Solution {
    public int findGCD(int[] nums) {
        int max=nums[0];
        int min=nums[0];
        for(int i=0;i<nums.length;i++){
            if(nums[i]<min){
                min=nums[i];
            }
            else if(nums[i]>max){
                max=nums[i];
            }
        }
        int count=0;
        for(int i=1;i<=min;i++){
            if(min%i==0 && max%i==0){
                count=i;
            }
        }
        return count;
    }
}/
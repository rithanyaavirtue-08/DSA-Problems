class Solution {
    public int[] rearrangeArray(int[] nums) {
        int[] ans =new int[nums.length];
        int positive=0;
        int negative=1;
        for(int i=0;i<nums.length;i++){
           if(nums[i]>0){
            ans[positive]=nums[i];
            positive+=2;
           }
           else{
            ans[negative]=nums[i];
            negative+=2;
           }

        }
        return ans;
    }
}
//here we are taking the index positive in even index and negative in the odd index

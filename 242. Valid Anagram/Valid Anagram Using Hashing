class Solution {
    public boolean isAnagram(String s, String t) {
      int [] hash=new int[26]; ////this the supplementry arrray

      for(int i=0;i<s.length();i++){
        if(s.length()!=t.length()){
            return false;
        }
        else{
          hash[s.charAt(i)-'a']++;
        }
      }
      for(int i=0;i<t.length();i++){
       hash[t.charAt(i)-'a']--;
      }
      for(int i=0;i<hash.length;i++){
        if(hash[i]!=0){
            return false;
        }
      }
      return true;
    }
}

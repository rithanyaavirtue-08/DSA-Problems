class Solution {
    public boolean isSubsequence(String s, String t) {
        int i=0;
        int j=0;
        while(i<s.length() && j<t.length()){
            if(s.charAt(i)==t.charAt(j)){
                i++;
            }
            j++;

        }
        if(i==(s.length())){
            return true;
        }
        else{
            return false;
        }


    }
    }
// here note that i will only increase only is j has its character or else it will not increase
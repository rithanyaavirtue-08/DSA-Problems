class Solution {
    public double myPow(double x, int n) {
        double result=1;
        long num=n;
        if(num< 0){  //when negative number, we can change it to positive and calculate the result,
                         //then take the reciprocal of the result
          x = 1 / x;
          num = -num;
}
        while(num>0){

            if(num%2==1){
                result*=x;
            }
            x=x*x; //when num is even, we can square x and half num, which can reduce the number of multiplications
            num=num/2;//when num is odd, we can multiply x to the result and then make num even, which can also reduce the number of multiplications

        }
        return result;

    }
}////////
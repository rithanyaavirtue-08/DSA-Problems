class Solution {
    public int singleNonDuplicate(int[] nums) {
        int low=0;
        int high=nums.length-1;
        while(low<high){
            int mid=(low+high)/2;
           if(mid%2==1){
            mid--;
           }
           if(nums[mid]==nums[mid+1]){ //checks the nearby value is there then ignore the left part
                                            //and move to right part because single element is in right part
            low=mid+2;
           }
           else{
            high=mid;
           }

        }
         return nums[low];
    }

}
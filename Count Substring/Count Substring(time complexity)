class Solution {
    public static int countSubstring(String s) {

        int count=0;
        for(int i=0;i<s.length();i++){
           for(int j=i;j<s.length();j++){
               String sums=s.substring(i,j+1);
               if(sums.contains("a") && sums.contains("b") && sums.contains("c")){
                   count++;
               }
           }

        }
        return count;

    }
}

class Solution {
    public int[] twoSum(int[] nums, int target) {
        HashMap <Integer,Integer> map =new HashMap<>();
        for(int i=0;i<nums.length;i++){

                int ans=target-nums[i];//2=9-7 ans=2 ; i=1(index)
                if(map.containsKey(ans)){
                    return new int[]{map.get(ans),i}; //from the key 2 gives the value as index,i=current index
                }
                map.put(nums[i],i); //if no it adds in map the key and the value

            }

        return new int[]{-1,-1};//no match it will return
    }
class Solution {
    public int findPeakElement(int[] nums) {
        int low=0;
        int high=nums.length-1;
        while(low<high){
            int mid=(low+high)/2;
            if(nums[mid]>nums[mid+1]){ // if mid is greater than its next value then it is a peak element and ignore the right part
                high=mid;
            }
            else{
                low=mid+1;
            }
        }
        return low;

    }
}
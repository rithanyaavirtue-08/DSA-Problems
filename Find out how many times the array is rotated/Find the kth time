class Solution {
    public int findKRotation(int arr[]) {
        int low=0;
        int high=arr.length-1;
        while(low<high){
            int mid=(low+high)/2;
            if(arr[mid]<=arr[high]){ //while finding th low number index we can find its rotation by its index
                high=mid;
            }
            else{
                low=mid+1;
            }
        }
        return low;

    }
}
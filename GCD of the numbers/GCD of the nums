class Solution {
    public static int gcd(int a, int b) {
        // code here
        while(b!=0){
            int temp=b;
            b=a%b;
            a=temp;//until the b becoms zero it will run and take
            //the value of a and b and assign the value of b to a and the remainder to b
        }
        return a;
    }
}

class Solution {
    public int maxConsecBits(int[] arr) {
        // code here
        int count=1;
        int maxCount=1;
        for(int i=0;i<arr.length-1;i++){
            if(arr[i]==arr[i+1]){
                count++;
            }
            else{
                count=1;
            }
            if(count>maxCount){
           maxCount=count;
       }

        }

       return maxCount;

    }
}

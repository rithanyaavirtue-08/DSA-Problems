class Solution {
    static void rotateArr(int arr[], int d) {
        int temp[]=new int[arr.length];
        d=d%arr.length;
            for(int j=0;j<arr.length;j++){
                if(j-d>=0){
                    temp[j-d]=arr[j];
                }
                else{
                    temp[arr.length+(j-d)]=arr[j];
                }

            }
            for(int i=0;i<arr.length;i++){
                arr[i]=temp[i];
            }

            }


}
class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int max=-1;
        int min=-1;
         for(int i=0;i<arr.length;i++){
            if(max<arr[i]){
             min=max;
             max=arr[i];
            }
         else if(arr[i]<max && arr[i]>min){
             min=arr[i];
         }

     }
     return min;

    }
}